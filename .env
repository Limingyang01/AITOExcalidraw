# AI Excalidraw 环境变量配置

# OpenAI API 配置 (支持 DeepSeek 等兼容 OpenAI API 的模型)
# 请将 your-openai-api-key-here 替换为你的实际 API Key
OPENAI_API_KEY=sk-754fe66588e34580bfe9c5922c304aa3

# API 基础 URL (默认使用 DeepSeek)
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 默认使用的模型
DEFAULT_MODEL=deepseek-chat

# 模型温度参数 (0-1, 越高越有创意)
DEFAULT_TEMPERATURE=0.7
